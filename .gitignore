# Generated by Cargo
# will have compiled files and executables
debug/
target/

miden-node/
miden-base/
dist/

# Remove web client lockfiles
yarn.lock
crates/web-client/**/package-lock.json

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Ignore Store files that may be spawned using `cargo run`
*.sqlite3

# Ignore mdbook build files
book/

# Docs platform ignores
.vscode
.code
.idea
site/
venv/
env/
*.out
node_modules/
*DS_Store
*.iml
*.ps1

# Ignore files that spawn using `miden-client init`
miden-client.toml
**/packages/**
!packages/
!packages/react-sdk/
!packages/react-sdk/**
packages/react-sdk/dist/
!packages/vite-plugin/
!packages/vite-plugin/**
packages/vite-plugin/dist/
packages/vite-plugin/node_modules/
!packages/node-sdk-darwin-arm64/
!packages/node-sdk-darwin-arm64/**
packages/node-sdk-darwin-arm64/*.node
!packages/node-sdk-darwin-x64/
!packages/node-sdk-darwin-x64/**
packages/node-sdk-darwin-x64/*.node
!packages/node-sdk-linux-x64-gnu/
!packages/node-sdk-linux-x64-gnu/**
packages/node-sdk-linux-x64-gnu/*.node
keystore/

# Ignore files that spawn using `cargo run`
miden-node.pid
data/

# Ignore files generated by playwright
crates/web-client/test-results
crates/web-client/playwright-report

# TypeScript incremental build cache
*.tsbuildinfo

# JS metadata generated from idxdb-store TypeScript build
crates/idxdb-store/src/js/**/*.d.ts
crates/idxdb-store/src/js/**/*.js.map
.claude/scheduled_tasks.lock
